{
  "name": "pythonbb-web",
  "version": "2.2.0",
  "private": true,
  "description": "Python Environment Management Tool",
  "author": "Ethan Wilkins",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "web": "node src/server.js",
    "desktop": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.weipython.desktop",
    "productName": "WeiPython Manager",
    "executableName": "WeiPython",
    "copyright": "© Ethan Wilkins",
    "icon": "build/icon.ico",
    "asar": false,
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "extraFiles": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "electron/**/*",
      "public/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "WeiPython-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "selectPerMachineByDefault": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "WeiPython Manager",
      "uninstallDisplayName": "WeiPython Manager",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
